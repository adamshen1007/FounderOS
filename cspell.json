    "API",
    "APIs",
    "Blackappl",
    "ChatGPT",
    "Codex",
    "DOCX",
    "Dominika",
    "EPUB",
    "evals",
    "FounderOS",
    "frontmatter",
    "GTM",
    "inspectable",
    "Mermaid",
    "Notion",
    "Obsidian",
    "Osterwalder",
    "Pandoc",
    "playbook",
    "playbooks",
    "pnpm",
    "roadmap",
    "rerunnable",
    "Ralston",
    "SaaS",
    "Seibel",
    "Speculor",
    "Strategyzer",
    "toolchain",
    "workflows",
    "YAML"
  ]
}
