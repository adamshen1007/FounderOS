{
  "version": "0.2",
  "language": "en,en-GB,en-US",
  "useGitignore": true,
  "enableGlobDot": true,
  "ignorePaths": [
    ".git/**",
    "build/**",
    "dist/**",
    "node_modules/**",
    "pnpm-lock.yaml"
  ],
  "ignoreRegExpList": ["Urls", "Email"],
