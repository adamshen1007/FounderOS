{
  "name": "founderos",
  "version": "0.4.0",
  "private": true,
  "description": "Documentation-first publishing foundation for FounderOS",
  "type": "module",
  "bin": {
    "founderos": "bin/founderos.mjs"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "check": "pnpm run check:tools && pnpm run check:markdown && pnpm run check:links && pnpm run check:spelling && pnpm run check:style && pnpm run check:diagrams && pnpm run check:citations && pnpm run test && pnpm run check:example",
    "check:tools": "node scripts/check-tools.mjs",
    "check:markdown": "markdownlint-cli2 \"**/*.md\" \"#node_modules/**\" \"#dist/**\" \"#build/**\"",
    "check:links": "node scripts/check-links.mjs",
    "check:spelling": "cspell lint \"**/*.md\" --no-progress --show-suggestions",
    "check:style": "node scripts/check-style.mjs",
    "check:diagrams": "node scripts/check-diagrams.mjs",
    "check:citations": "node scripts/check-citations.mjs",
    "check:example": "node bin/founderos.mjs generate examples/ai-launch-copilot/founderos.project.yaml --check",
    "founderos": "node bin/founderos.mjs",
    "test": "node --test tests/*.test.mjs",
    "build": "node scripts/build-book.mjs",
    "verify:outputs": "node scripts/verify-outputs.mjs",
    "preview": "node scripts/preview.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "ajv": "8.17.1",
    "cspell": "^10.0.1",
    "markdownlint-cli2": "^0.23.0",
    "yaml": "^2.9.0"
  }
}
