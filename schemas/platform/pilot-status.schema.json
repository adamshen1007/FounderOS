{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderOS pilot status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "sessions",
    "projects",
    "dateSpanDays",
    "tasks",
    "outcomes",
    "automatedCriteriaMet",
    "decision"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "sessions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed", "required"],
      "properties": {
        "observed": { "type": "integer", "minimum": 0 },
        "required": { "const": 10 }
      }
    },
    "projects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["represented", "required", "ids"],
      "properties": {
        "represented": { "type": "integer", "minimum": 0 },
        "required": { "const": 3 },
        "ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "dateSpanDays": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed", "required", "first", "last"],
      "properties": {
        "observed": { "type": "integer", "minimum": 0 },
        "required": { "const": 14 },
        "first": { "type": ["string", "null"], "format": "date" },
        "last": { "type": ["string", "null"], "format": "date" }
      }
    },
    "tasks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed", "required", "missing"],
      "properties": {
        "observed": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "required": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "missing": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completed", "blocked", "abandoned"],
      "properties": {
        "completed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "abandoned": { "type": "integer", "minimum": 0 }
      }
    },
    "automatedCriteriaMet": { "type": "boolean" },
    "decision": {
      "enum": ["collecting-evidence", "manual-review-required"]
    }
  }
}
