{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderOS workflow job",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "projectId", "workflow", "status", "createdAt", "updatedAt", "startedAt", "completedAt", "durationMs", "command", "log", "outputTruncated", "terminationReason"],
  "properties": {
    "schemaVersion": { "const": 1 }, "id": { "type": "string", "pattern": "^JOB-[A-Z0-9-]+$" }, "projectId": { "type": "string" }, "workflow": { "type": "string" }, "status": { "enum": ["queued", "running", "passed", "failed", "cancelled"] }, "createdAt": { "type": "string", "format": "date-time" }, "updatedAt": { "type": "string", "format": "date-time" }, "startedAt": { "type": ["string", "null"], "format": "date-time" }, "completedAt": { "type": ["string", "null"], "format": "date-time" }, "durationMs": { "type": ["integer", "null"], "minimum": 0 }, "command": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "log": { "type": "string", "maxLength": 20000 }, "outputTruncated": { "type": "boolean" }, "terminationReason": { "type": ["string", "null"] }, "parentJobId": { "type": "string", "pattern": "^JOB-[A-Z0-9-]+$" }, "exitCode": { "type": ["integer", "null"] }
  }
}
