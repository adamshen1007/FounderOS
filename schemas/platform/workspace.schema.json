{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderOS workspace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workspace", "projects"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "workspace": { "type": "object", "additionalProperties": false, "required": ["name", "owner"], "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 100 }, "owner": { "type": "string", "minLength": 1, "maxLength": 100 } } },
    "projects": { "type": "array", "minItems": 2, "maxItems": 20, "items": { "type": "object", "additionalProperties": false, "required": ["id", "kind", "path"], "properties": { "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }, "kind": { "enum": ["repository", "kit"] }, "path": { "type": "string", "minLength": 1 }, "manifest": { "type": "string", "minLength": 1 } } } }
  }
}
