{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderos.dev/schemas/agents/agent-definition.schema.json",
  "title": "FounderOS agent definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "status", "purpose", "prompt", "model", "permissions", "limits", "outputSchema"],
  "$defs": {
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeoutMs", "maxInputTokens", "maxOutputTokens", "maxCostUsd", "maxFiles"],
      "properties": {
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 300000 },
        "maxInputTokens": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "maxOutputTokens": { "type": "integer", "minimum": 1, "maximum": 100000 },
        "maxCostUsd": { "type": "number", "minimum": 0, "maximum": 1000 },
        "maxFiles": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    }
  },
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "name": { "type": "string", "minLength": 3 },
    "status": { "enum": ["enabled", "contract-only", "disabled"] },
    "purpose": { "type": "string", "minLength": 10 },
    "prompt": { "type": "string", "pattern": "^agents/prompts/[a-z0-9-]+\\.md$" },
    "model": { "type": "object", "additionalProperties": false, "required": ["provider", "name"], "properties": { "provider": { "enum": ["fake", "openai"] }, "name": { "type": "string", "minLength": 1 } } },
    "permissions": { "type": "object", "additionalProperties": false, "required": ["read", "propose", "shell", "network", "git", "publish"], "properties": { "read": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "propose": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "shell": { "const": false }, "network": { "const": false }, "git": { "const": false }, "publish": { "const": false } } },
    "limits": { "$ref": "#/$defs/limits" },
    "outputSchema": { "const": "schemas/agents/proposal.schema.json" },
    "fixture": { "type": "string", "pattern": "^agents/fixtures/[a-z0-9-]+\\.json$" }
  }
}
