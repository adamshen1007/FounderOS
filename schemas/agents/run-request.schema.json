{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderOS agent run request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "agentId", "subject", "provider", "model", "createdAt", "inputs", "limits"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,63}$" },
    "agentId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
    "subject": { "type": "string", "minLength": 1 },
    "provider": { "enum": ["fake", "openai"] },
    "model": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "inputs": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["path", "sha256", "bytes"], "properties": { "path": { "type": "string", "minLength": 1 }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "bytes": { "type": "integer", "minimum": 0 } } } },
    "limits": { "$ref": "agent-definition.schema.json#/$defs/limits" }
  }
}
