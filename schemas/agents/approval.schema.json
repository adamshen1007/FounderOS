{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FounderOS human approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "decision", "reviewer", "reviewedAt", "proposalHash", "files"],
  "properties": {
    "schemaVersion": { "const": 1 }, "runId": { "type": "string" }, "decision": { "enum": ["approved", "rejected"] }, "reviewer": { "type": "string", "minLength": 2 }, "reviewedAt": { "type": "string", "format": "date-time" }, "proposalHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "files": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": { "path": { "type": "string" }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } } }, "note": { "type": "string", "maxLength": 2000 }
  }
}
